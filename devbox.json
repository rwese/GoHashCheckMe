{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "packages": [
    "golangci-lint@latest",
    "go@1.24",
    "gopls@latest"
  ],
  "shell": {
    "init_hook": [
      "echo 'Welcome to devbox!' > /dev/null"
    ],
    "scripts": {
      "test": "go test -short ./...",
      "lint": "golangci-lint run",
      "vet": "go vet ./...",
      "fmt": "go fmt ./..."
    }
  }
}
